{
    "name": "tickatlas/php-sdk",
    "description": "Official PHP SDK for the TickAtlas API (forex/markets data, indicators, calendar).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tickatlas",
        "forex",
        "trading",
        "market-data",
        "indicators",
        "sdk",
        "api-client"
    ],
    "homepage": "https://tickatlas.com",
    "support": {
        "issues": "https://github.com/abuzant/tickatlas-sdk/issues",
        "source": "https://github.com/abuzant/tickatlas-sdk"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "TickAtlas\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TickAtlas\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
